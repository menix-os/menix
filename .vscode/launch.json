{
	"version": "0.2.0",
	"configurations": [
		{
			"type": "lldb",
			"request": "custom",
			"name": "Debug x86_64",
			"targetCreateCommands": [
				"target create ${workspaceFolder}/../bootstrap/build/install/boot/menix",
